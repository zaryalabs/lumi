LUMI_SERVER_BIND=127.0.0.1:8080
DATABASE_URL=postgres://lumi:lumi-local@127.0.0.1:5432/lumi
LUMI_API_BASE=http://127.0.0.1:8080/api/v1
LUMI_WEB_ORIGIN=http://127.0.0.1:5173
LUMI_AUTH_AUDIENCE=http://127.0.0.1:5173
# Hosted HTTPS deployment must set this to true for __Host-lumi_session.
LUMI_SECURE_COOKIE=false
RUST_LOG=info,lumi_server=debug,tower_http=debug
