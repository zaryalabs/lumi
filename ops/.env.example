# Pin third-party images by digest before production bootstrap.
LUMI_POSTGRES_IMAGE=postgres:17-alpine
LUMI_BLOB_INIT_IMAGE=busybox:1.37

LUMI_POSTGRES_PASSWORD=replace-with-secret-store-value
LUMI_DATABASE_URL=postgres://lumi:replace-with-url-encoded-secret-store-value@postgres:5432/lumi

LUMI_DOMAIN=lumi.zrya.io
LUMI_WEB_ORIGIN=https://lumi.zrya.io
TRAEFIK_CERT_RESOLVER=letsencrypt

LUMI_TELEGRAM_BOT_SCOPE=lumi-production
LUMI_TELEGRAM_BOT_USERNAME=
LUMI_TELEGRAM_WEBHOOK_SECRET=

LUMI_BACKUP_REQUIRE_SEEDED=1
RUST_LOG=info,tower_http=info
