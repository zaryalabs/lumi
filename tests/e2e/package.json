{
  "name": "@lumi/e2e",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "format": "node ./node_modules/prettier/bin/prettier.cjs --write .",
    "format:check": "node ./node_modules/prettier/bin/prettier.cjs --check .",
    "lint": "node ./node_modules/typescript/bin/tsc --noEmit",
    "typecheck": "node ./node_modules/typescript/bin/tsc --noEmit",
    "test": "node ./node_modules/@playwright/test/cli.js test",
    "test:pagination-spike": "node ./node_modules/@playwright/test/cli.js test --config pagination-spike.playwright.config.ts",
    "test:prototype": "node ./node_modules/@playwright/test/cli.js test --config prototype.playwright.config.ts",
    "install-browsers": "node ./node_modules/@playwright/test/cli.js install chromium"
  },
  "devDependencies": {
    "@playwright/test": "^1.57.0",
    "@types/node": "^25.0.1",
    "prettier": "^3.7.4",
    "typescript": "^5.9.3"
  }
}
